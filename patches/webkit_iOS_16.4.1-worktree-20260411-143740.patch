+    if (!decoder.decode(result.m_altitudeAngle))
+        return std::nullopt;
+    if (!decoder.decode(result.m_azimuthAngle))
+        return std::nullopt;
+    if (!decoder.decode(result.m_touchType))
+        return std::nullopt;
